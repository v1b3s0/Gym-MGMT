# Compiled Java files
*.class

# Java build output folders
bin/
out/
build/
target/

# IDE/editor settings
.vscode/
.idea/
.settings/
.classpath
.project

# Runtime CSV data files
# The program creates these locally in /data.
# Keep them off GitHub unless you intentionally want sample data committed.
data/*.csv

# Logs
*.log

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package files
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# JVM crash logs
hs_err_pid*
replay_pid*

# --- Gradle ---
# Local Gradle cache for this project (safe to delete, never committed)
.gradle/

# The wrapper JAR is committed on purpose, so clones and CI run the pinned
# Gradle with zero install. Re-include it past the blanket *.jar rule above.
!gradle/wrapper/gradle-wrapper.jar
